# --- Secrets / key material (Constraint 5: never commit) ---
# TPM context files and private blobs (EK/AK private parts live inside these)
attester/keys/
*.ctx
*.priv
*.sealed
sealed_*
*.key
*.pem.priv

# NOTE: AK *public* material is allowed in git (verifier/ak.pub, verifier/ak_pub.pem)
# and is explicitly NOT ignored. Same for the policy public (attester/policy_pub.pem).

# verifier's policy-authorization private key (signs unseal authorizations)
verifier/policy_key.pem

# --- swtpm state (contains the software TPM's seed/NV state) ---
dev/swtpm-state/
*.permall
# generated, machine-local TCTI env
dev/tcti.env

# --- Runtime artifacts (quotes, sigs, fetched evidence) ---
attester/out/
verifier/runtime/

# --- AI model blobs (Phase 2): the gated artifact; never commit (Constraint 5).
# attester/models/README.md IS committed (the model contract); the blobs are not.
attester/models/*.tflite
attester/models/*.hef

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Hailo SDK / NPU toolchain ---
hailo_venv/
*.whl
.install_logs/
*.log

# --- Editor noise ---
*.swp
.DS_Store
